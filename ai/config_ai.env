# =============================================================
# GS4PB Shiny App (AI Version) - Configuration
# Edit these values to match your environment
# =============================================================

# Path to the AI version Singularity/Apptainer image
# Pull with: singularity pull gs4pb_ai.sif docker://umnlorenzgroup/gs4pb:ai-latest
SIF_IMAGE="gs4pb_ai.sif"

# Shiny app path inside the container
APP="/srv/shiny-server"

# Port to expose the Shiny app on
PORT=8080

# Host (0.0.0.0 = all interfaces; use 127.0.0.1 for localhost-only)
HOST="0.0.0.0"
