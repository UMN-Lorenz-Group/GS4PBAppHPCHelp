# =============================================================
# GS4PB Shiny App - Configuration
# Edit these values to match your environment
# =============================================================

# Path to the Singularity/Apptainer image
SIF_IMAGE="gs4pb_updated.sif"

# Path to the Shiny app inside the container
APP="/srv/shiny-server/App"

# R library path inside the container
LIB="/srv/shiny-server/App/renv/library/linux-ubuntu-jammy/R-4.4/x86_64-pc-linux-gnu"

# Port to expose the Shiny app on
PORT=3838

# Host (0.0.0.0 = all interfaces; use 127.0.0.1 for localhost-only)
HOST="0.0.0.0"
